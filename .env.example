# Copy to .env and fill in. docker-compose reads this automatically.

# ntfy topic to publish alerts to. Pick something unguessable — anyone who
# knows the topic name on a public server can read your notifications.
NTFY_TOPIC=sentinel-changeme-7f3a

# Optional: self-hosted/alternate ntfy server (defaults to https://ntfy.sh)
# NTFY_SERVER=https://ntfy.sh

# Optional: credentials for a protected ntfy topic
# NTFY_USER=
# NTFY_PASS=

# Optional: a GitHub token raises the API rate limit for github_releases sources
# GITHUB_TOKEN=
